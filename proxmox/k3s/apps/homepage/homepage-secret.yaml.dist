apiVersion: v1
kind: Secret
metadata:
  name: homepage-secret
  namespace: homepage
type: Opaque
stringData:
  HOMEPAGE_VAR_ADGUARD_USER: "changeme"
  HOMEPAGE_VAR_ADGUARD_PASSWORD: "changeme"
  HOMEPAGE_VAR_GRAFANA_USER: "changeme"
