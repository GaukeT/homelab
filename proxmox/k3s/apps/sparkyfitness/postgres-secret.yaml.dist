# This file is a template — do NOT commit real values to Git.
# The helm chart references secret "sparkyfitness-postgres" (keys: username, password)
# but does NOT create it. You must create it manually:
#
#   kubectl create namespace sparkyfitness || true
#   kubectl create secret generic sparkyfitness-postgres \
#     --namespace=sparkyfitness \
#     --from-literal=username=sparky \
#     --from-literal=password=changeme
#
apiVersion: v1
kind: Secret
metadata:
  name: sparkyfitness-postgres
  namespace: sparkyfitness
type: Opaque
stringData:
  username: "sparky"
  password: "changeme"

